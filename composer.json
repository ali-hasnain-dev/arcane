{
    "name": "larafusion/larafusion",
    "description": "Larafusion — JS powered admin panel for Laravel",
    "type": "library",
    "repositories": [
        {
            "type": "path",
            "url": "./packages/support"
        },
        {
            "type": "path",
            "url": "./packages/actions"
        },
        {
            "type": "path",
            "url": "./packages/forms"
        },
        {
            "type": "path",
            "url": "./packages/tables"
        },
        {
            "type": "path",
            "url": "./packages/schemas"
        },
        {
            "type": "path",
            "url": "./packages/infolists"
        },
        {
            "type": "path",
            "url": "./packages/widgets"
        },
        {
            "type": "path",
            "url": "./packages/panels"
        }
    ],
    "require": {
        "php": "^8.2",
        "larafusion/support": "@dev",
        "larafusion/actions": "@dev",
        "larafusion/forms": "@dev",
        "larafusion/tables": "@dev",
        "larafusion/schemas": "@dev",
        "larafusion/widgets": "@dev",
        "larafusion/panels": "@dev"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}