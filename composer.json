{
    "name": "larafusion/larafusion",
    "description": "Larafusion — JS powered admin panel for Laravel",
    "type": "project",
    "repositories": [
        {
            "type": "path",
            "url": "./packages/support"
        },
        {
            "type": "path",
            "url": "./packages/actions"
        },
        {
            "type": "path",
            "url": "./packages/forms"
        },
        {
            "type": "path",
            "url": "./packages/tables"
        },
        {
            "type": "path",
            "url": "./packages/schemas"
        },
        {
            "type": "path",
            "url": "./packages/infolists"
        },
        {
            "type": "path",
            "url": "./packages/widgets"
        },
        {
            "type": "path",
            "url": "./packages/panels"
        }
    ],
    "require": {
        "larafusion/larafusion": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}