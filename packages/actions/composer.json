{
    "name": "larafusion/actions",
    "description": "Larafusion actions — button, link, and custom action definitions for resources and pages.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "larafusion/support": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Larafusion\\Actions\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larafusion\\Actions\\ActionsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
