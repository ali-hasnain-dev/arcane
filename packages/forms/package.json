{
    "name": "@larafusion/forms",
    "version": "0.1.0",
    "description": "Larafusion forms \u2014 field components, hybrid validation, repeater, tags, file uploads, and relation fields",
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.esm.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "dev": "vite build --watch",
        "build": "tsc && vite build",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@inertiajs/react": "^3.0.0",
        "@larafusion/support": "*",
        "laravel-precognition-react-inertia": "^0.8.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "typescript": "^5.4.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "lucide-react": "^1.17.0",
        "clsx": "^2.1.0"
    }
}
