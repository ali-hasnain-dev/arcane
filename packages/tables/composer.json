{
    "name": "larafusion/tables",
    "description": "Larafusion tables — column definitions, filters, bulk actions, and table schema.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "larafusion/support": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Larafusion\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larafusion\\Tables\\TablesServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
