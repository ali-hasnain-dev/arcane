{
    "name": "larafusion/panels",
    "description": "Larafusion panels — admin panel, resources, pages, navigation, plugins, and theme management.",
    "type": "library",
    "keywords": ["laravel", "react", "admin", "inertia", "crud", "panel"],
    "license": "MIT",
    "authors": [
        {
            "name": "Larafusion",
            "email": "hello@larafusion.dev",
            "homepage": "https://larafusion.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^2.0",
        "larafusion/actions": "@dev",
        "larafusion/forms": "@dev",
        "larafusion/tables": "@dev",
        "larafusion/widgets": "@dev",
        "larafusion/schemas": "@dev",
        "larafusion/support": "@dev"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Larafusion\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Larafusion\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larafusion\\LarafusionServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
