{
    "name": "arcane/panels",
    "description": "Arcane panels — admin panel, resources, pages, navigation, plugins, and theme management.",
    "type": "library",
    "keywords": ["laravel", "react", "admin", "inertia", "crud", "panel"],
    "license": "MIT",
    "authors": [
        {
            "name": "Arcane",
            "email": "hello@arcane.dev",
            "homepage": "https://arcane.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "inertiajs/inertia-laravel": "^2.0",
        "arcane/actions": "^0.1",
        "arcane/forms": "^0.1",
        "arcane/tables": "^0.1",
        "arcane/widgets": "^0.1",
        "arcane/schemas": "^0.1",
        "arcane/support": "^0.1"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Arcane\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Arcane\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arcane\\ArcaneServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
