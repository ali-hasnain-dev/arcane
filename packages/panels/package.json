{
    "name": "@larafusion/panels",
    "version": "0.1.0",
    "description": "Larafusion panels \u2014 admin layout, pages, auth, plugin registry, and theme provider",
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.esm.js",
            "types": "./dist/index.d.ts"
        },
        "./layout": "./dist/layout.esm.js",
        "./auth": "./dist/auth.esm.js",
        "./theme": "./dist/theme.esm.js"
    },
    "scripts": {
        "dev": "vite build --watch",
        "build": "tsc && vite build",
        "typecheck": "tsc --noEmit",
        "lint": "eslint resources/js --ext .ts,.tsx"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@inertiajs/react": "^3.0.0",
        "@larafusion/support": "*",
        "@larafusion/forms": "*",
        "@larafusion/tables": "*",
        "@larafusion/widgets": "*"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^6.0.2",
        "@inertiajs/vite": "^3.0.0",
        "autoprefixer": "^10.4.0",
        "postcss": "^8.4.0",
        "tailwindcss": "^3.4.0",
        "typescript": "^5.4.0",
        "vite": "^8.0.0"
    },
    "dependencies": {
        "lucide-react": "^1.17.0",
        "clsx": "^2.1.0"
    }
}
