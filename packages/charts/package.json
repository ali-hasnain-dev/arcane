{
    "name": "@arcane/charts",
    "version": "0.1.0",
    "description": "Arcane charts \u2014 dashboard chart widgets and data visualizations powered by Recharts",
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.esm.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "dev": "vite build --watch",
        "build": "tsc && vite build",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "@arcane/support": "*",
        "recharts": "^2.0.0"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "typescript": "^5.4.0",
        "vite": "^8.0.0"
    }
}
