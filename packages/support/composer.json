{
    "name": "larafusion/support",
    "description": "Larafusion support — shared utilities, helpers, and base classes used across all Larafusion packages.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Larafusion\\Support\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larafusion\\Support\\SupportServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
