{
    "name": "larafusion/schemas",
    "description": "Larafusion schemas — schema serialization and component schema definitions.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "larafusion/support": "@dev"
    },
    "autoload": {
        "psr-4": {
            "Larafusion\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Larafusion\\Schema\\SchemasServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
